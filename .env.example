# Credenciais INLABS (obrigatório para o eixo federal)
INLABS_EMAIL=
INLABS_PASSWORD=

# Chave que o Apps Script envia no header X-API-Key (defina uma string forte)
API_KEY=

# Diretório de dados (SQLite). No Railway: monte um Volume em /data e use DATA_DIR=/data
DATA_DIR=./data

# Opcionais (têm padrão sensato)
SECTIONS=DO1,DO1E
TZ=America/Sao_Paulo
SESSION_TTL_MIN=30
BLOCK_BACKOFF_MIN=120
